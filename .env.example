# Copy to .env (already gitignored) and fill in real values.

# Cloudflare Zero Trust → Networks → Tunnels → your tunnel → "Install and run
# a connector" gives you this token. Configure the public hostname → this
# tunnel's routing (Public Hostname tab) to point at http://app:3001.
TUNNEL_TOKEN=

# Only needed if you switch database.js off the local-SQLite-in-volume setup
# (see docker-compose.yml) and back to Turso.
# TURSO_AUTH_TOKEN=
